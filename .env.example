# ─── Azure AD / Entra ID ───────────────────────────────────────────────────
# Get these from Azure Portal > App registrations > your app > Overview
VITE_AZURE_CLIENT_ID=YOUR_APP_CLIENT_ID_HERE
VITE_AZURE_TENANT_ID=YOUR_TENANT_ID_HERE

# ─── SharePoint ────────────────────────────────────────────────────────────
VITE_SHAREPOINT_SITE_URL=https://quandatics.sharepoint.com/sites/QuandaticsPortal-Admin
VITE_SHAREPOINT_SITE_ID=YOUR_SITE_ID_HERE

# ─── Power Automate HTTP Triggers ─────────────────────────────────────────
# Paste the HTTP POST URL from each flow's trigger step
VITE_FLOW_SUBMIT_URL=YOUR_POWER_AUTOMATE_SUBMIT_FLOW_URL
